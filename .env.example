# Copy to .env and adjust. Loaded by app/config.py (pydantic-settings).

# Postgres (uses the locally running postgresql@17 by default).
# On Homebrew Postgres the default superuser is your macOS username with no password.
AI_DATABASE_URL=postgresql://kennethrona@localhost:5432/ad_integrity

# Connection pool sizing
AI_DB_POOL_MIN=2
AI_DB_POOL_MAX=10

# Tiered TTLs (seconds)
AI_PAGE_TTL_SECONDS=604800     # 7 days  — page-level scan result freshness
AI_DOMAIN_TTL_SECONDS=86400    # 24 hours — domain-level signal freshness

# sellers.json cross-resolution (global per-ad-system cache)
AI_SELLERS_JSON_TTL_SECONDS=604800     # 7 days
AI_SELLERS_JSON_NEG_TTL_SECONDS=86400  # cache misses/failures for 1 day
AI_SELLERS_JSON_MAX_BYTES=15000000     # streaming cap; bigger files recorded as too_large
AI_SELLERS_JSON_MAP_MAX=100000         # store the id->seller map only below this size
AI_SUPPLY_RESOLVE_MAX_SYSTEMS=30       # ad systems resolved per publisher scan

# Static-tier query-param stripping: tracking params removed before hashing/dedup
AI_STRIP_TRACKING_PARAMS=true

# Content category / brand-suitability classifier.
# auto = embedding model (model2vec) if available else keyword; ml; keyword.
AI_CONTENT_CLASSIFIER=auto

# Worker tuning
AI_STATIC_WORKER_BATCH=20         # jobs claimed per poll
AI_STATIC_WORKER_CONCURRENCY=8    # jobs processed in parallel (I/O-bound)
AI_STATIC_WORKER_POLL_MS=250      # idle poll interval
AI_MAX_ATTEMPTS=3              # claims per job before it is parked as 'error'

# Render tier (Playwright). sample_rate = fraction of static scans also rendered.
# 1.0 = render everything (dev); production would set ~0.05-0.10.
AI_RENDER_ENABLED=true
AI_RENDER_SAMPLE_RATE=1.0
AI_RENDER_CONCURRENCY=2        # concurrent browser contexts
AI_RENDER_DWELL_MS=8000        # dwell after load to let ads fill/refresh + viewability accrue
AI_RENDER_SAMPLES=1            # >1: render N times, take median CLS (N x render cost)
AI_RENDER_WORKER_BATCH=4
# Resource types aborted during render. Keeps images (accurate page weight);
# add 'image' (e.g. "image,font,media") to cut bandwidth at the cost of weight accuracy.
AI_RENDER_BLOCK_RESOURCES=font,media

# Maintenance worker (Phase 4)
AI_VISIBILITY_TIMEOUT_SECONDS=300   # 'processing' jobs older than this get reaped
AI_QUEUE_RETENTION_SECONDS=86400    # done/error queue rows pruned after this
AI_MAINTENANCE_INTERVAL_SECONDS=60
AI_RESCAN_ENABLED=false             # re-enqueue URLs whose page TTL expired
AI_RESCAN_BATCH=100

# Logging
AI_LOG_LEVEL=INFO

# Scanner/scoring versions stamped on every record
AI_SCANNER_VERSION=0.1.0
AI_SCORING_VERSION=0.1.0
